# Copy this file to application-local.properties and set your real Postgres password.
# application-local.properties is gitignored — never commit credentials.
#
# Run locally: mvn spring-boot:run
# (the local profile is enabled automatically via pom.xml)

spring.datasource.url=jdbc:postgresql://localhost:5432/staffratings
spring.datasource.username=postgres
spring.datasource.password=yourpassword
